# Backend API origin for production.
# Use the backend URL only, without a trailing /api.
# Example: VITE_API_URL=https://your-backend-ngrok-url.ngrok-free.app
#
# Leave this empty during local development if you run the Vite dev server,
# because vite.config.js proxies /api to http://localhost:5000.
VITE_API_URL=
