# 1. Create a free PostgreSQL database at https://neon.tech or https://supabase.com
# 2. Get your connection string (it looks like postgresql://user:password@host/db)
DATABASE_URL="postgresql://user:password@localhost:5432/nutritrack"
DIRECT_URL="postgresql://user:password@localhost:5432/nutritrack"

# 3. Create a random string for your JWT secret
JWT_SECRET="your_super_secret_jwt_key_here"

# 4. Get your free Gemini API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# 5. Set the frontend origin in production.
# Use your deployed Vercel URL, not localhost, so password-reset links are correct.
# Example:
# CORS_ORIGIN="https://nutri-track-sage.vercel.app"
# FRONTEND_URL="https://nutri-track-sage.vercel.app"
CORS_ORIGIN=""
FRONTEND_URL="http://localhost:5173"

# 6. Email settings for password reset emails.
# On Render free instances, SMTP ports are often blocked. Prefer SendGrid or Resend
# API keys in production because they send over HTTPS.
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL=""
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Optional SMTP/Gmail fallback for local development or paid hosts.
# Gmail users should use an App Password, not their normal account password.
EMAIL="yourgmail@gmail.com"
EMAIL_PASSWORD="your_gmail_app_password"
EMAIL_FROM="NutriTrack <yourgmail@gmail.com>"

# Optional SMTP alternative:
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="smtp_user"
# SMTP_PASSWORD="smtp_password"
